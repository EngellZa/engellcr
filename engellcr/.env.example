# ─── Configuración Django ─────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
ALLOWED_HOSTS=tu-dominio.railway.app,localhost,127.0.0.1
# Solo si probás localmente con DEBUG=False sobre HTTP plano (evita el redirect a HTTPS):
SECURE_SSL_REDIRECT=

# ─── Base de datos (Railway PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ─── Cache (opcional — sin esto usa memoria local) ────────────────────────────
REDIS_URL=

# ─── Cloudinary (logos, PDFs, comprobantes) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── Correo (opcional — sin esto los correos se imprimen en consola) ──────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# ─── Tilopay (arquitectura preparada — sin credenciales reales aún) ───────────
TILOPAY_API_KEY=
TILOPAY_API_SECRET=
TILOPAY_MERCHANT_ID=
TILOPAY_WEBHOOK_SECRET=
TILOPAY_ENVIRONMENT=sandbox
TILOPAY_RETURN_URL=
TILOPAY_CANCEL_URL=

# ─── PayPal (arquitectura preparada — sin credenciales reales aún) ────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=

# ─── SINPE Móvil (mostrado al cliente en instrucciones de pago) ───────────────
SINPE_MOBILE_NUMBER=
SINPE_ACCOUNT_HOLDER=

# ─── Contacto ──────────────────────────────────────────────────────────────
WHATSAPP_CONTACT_NUMBER=
ADMIN_EMAIL=
